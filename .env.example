# Database connection settings for the Python Password Manager.
# Copy this file to `.env` (or export these variables in your shell) and fill
# in your own values. NEVER commit real secrets.
#
# The application reads these via os.environ in src/utils/dbconfig.py.

# Hostname of the MySQL/MariaDB server (default: localhost)
DB_HOST=localhost

# Port of the MySQL/MariaDB server (default: 3306)
DB_PORT=3306

# Database user (default: root)
DB_USER=root

# Optional: default database/schema to connect to. The app fully-qualifies its
# tables as `pm.secret` / `pm.entries`, so this can be left unset.
DB_NAME=pm

# REQUIRED: database password. There is intentionally no default — the app
# will refuse to start if this is unset.
DB_PASSWORD=change-me
